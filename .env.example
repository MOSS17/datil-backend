# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://datil:datil@localhost:5432/datil?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Bcrypt
BCRYPT_COST=12

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Twilio (WhatsApp notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Storage: "local" (dev) or "r2"
STORAGE_PROVIDER=local
LOCAL_UPLOAD_ROOT=./.uploads
LOCAL_PUBLIC_BASE_URL=http://localhost:8080/static/uploads

# Cloudflare R2 (production)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
