# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://datil:datil@localhost:5432/datil?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Bcrypt
BCRYPT_COST=12

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Twilio (WhatsApp notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Storage: "local" (dev) or "r2"
STORAGE_PROVIDER=local
LOCAL_UPLOAD_ROOT=./.uploads
LOCAL_PUBLIC_BASE_URL=http://localhost:8080/static/uploads

# Cloudflare R2 (production)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Google Calendar OAuth (optional — leave blank to disable /calendar/google/*)
# Redirect URL must match what you register in Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/calendar/google/callback

# Frontend base URL used for the Google OAuth post-callback redirect.
# If blank, the first CORS_ALLOWED_ORIGINS entry is used.
FRONTEND_BASE_URL=http://localhost:3000

# Externally-reachable API origin. Used to build webcal:// subscription
# URLs returned by /calendar/ics/connect. No trailing slash. In dev,
# defaults to http://localhost:<PORT> if blank.
API_PUBLIC_BASE_URL=
